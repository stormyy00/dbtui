{
  "name": "dbtui",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "engine:build": "cargo build --manifest-path crates/Cargo.toml",
    "engine:build:release": "cargo build --release --manifest-path crates/Cargo.toml"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
